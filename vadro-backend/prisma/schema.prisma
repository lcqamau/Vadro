// Connexion à PostgreSQL
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Générateur du client JS pour le code
generator client {
  provider = "prisma-client-js"
}

// +++ NOUVEAU : Enum pour les types d'étapes +++
enum StepType {
  spot
  sleep
  eat
  activity
  start
  end
}

// --- 1. L'UTILISATEUR (L'Éclaireur) ---
model User {
  id          Int      @id @default(autoincrement())
  email       String   @unique
  username    String
  password    String   // Essentiel pour l'authentification
  avatarUrl   String?
  bio         String?
  trustScore  Int      @default(100)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  trips       Trip[]      @relation("Author")
  favorites   Favorite[]
  reviews     Review[]
}

// --- 2. LE VOYAGE (L'entité principale) ---
model Trip {
  id           Int      @id @default(autoincrement())
  title        String
  description  String?
  
  distanceKm   Int      @default(0)
  durationDays Int      @default(1)
  budgetEuro   Int      @default(0)
  
  imageUrl     String?
  
  tags         String[]
  isPublic     Boolean  @default(true)
  
  status       TripStatus @default(PLANNED) 
  startDate    DateTime?
  endDate      DateTime?

  originalTripId Int?
  originalTrip   Trip?  @relation("RemixHistory", fields: [originalTripId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  remixes        Trip[] @relation("RemixHistory")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  authorId     Int
  author       User     @relation("Author", fields: [authorId], references: [id], onDelete: Cascade)
  
  steps        Step[]
  reviews      Review[]
  favorites    Favorite[]
}

enum TripStatus {
  PLANNED
  ACTIVE
  COMPLETED
  PUBLISHED
}

// --- 3. L'ÉTAPE (Le détail du tracé GPS) ---
model Step {
  id          Int      @id @default(autoincrement())
  orderIndex  Int
  title        String
  day         Int      @default(0)
  description String?
  
  latitude    Float?
  longitude   Float?
  
  // +++ AMÉLIORATION : Utilisation de l'Enum StepType +++
  type        StepType @default(spot)
  imageUrl    String?

  // +++ AMÉLIORATION : Suivi des modifications +++
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tripId      Int
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

// --- 4. LES FAVORIS (Le Swipe Tinder) ---
model Favorite {
  id        Int      @id @default(autoincrement())
  likedAt   DateTime @default(now())

  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tripId    Int
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([userId, tripId])
}

// --- 5. LES AVIS (La Réputation) ---
model Review {
  id        Int      @id @default(autoincrement())
  rating    Int
  comment   String?
  
  createdAt DateTime @default(now())
  // +++ AMÉLIORATION : Suivi des modifications +++
  updatedAt DateTime @updatedAt
  
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  tripId    Int
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)

  // +++ AMÉLIORATION : Un utilisateur ne peut laisser qu'un seul avis par voyage +++
  @@unique([userId, tripId])
}